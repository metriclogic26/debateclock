{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/j/:name",
      "destination": "/app/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.debateclock.org"
        }
      ],
      "destination": "https://debateclock.org/:path*",
      "permanent": true
    }
  ]
}